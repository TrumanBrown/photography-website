---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import { sessionSlug, formatDate } from '@/lib/sessions';

interface Props {
  entry: CollectionEntry<'sessions'>;
  cover: ImageMetadata;
}

const { entry, cover } = Astro.props;
const slug = sessionSlug(entry);
const { title, date, location, images } = entry.data;
const photoCount = images.length;
const hasMultiple = photoCount > 1;
---

<a href={`/sessions/${slug}`} class="group block no-underline">
  <div class="relative">
    {
      hasMultiple && (
        <>
          {/* Stack effect: two thin offset cards behind the cover suggest a pile of photos.
              Pure CSS, no extra assets. Disabled at <sm to avoid clutter. */}
          <div
            aria-hidden="true"
            class="absolute inset-0 hidden translate-x-1.5 translate-y-1.5 rounded-lg bg-neutral-200 transition-transform duration-300 group-hover:translate-x-2 group-hover:translate-y-2 dark:bg-neutral-800 sm:block"
          />
          <div
            aria-hidden="true"
            class="absolute inset-0 hidden translate-x-0.5 translate-y-0.5 rounded-lg bg-neutral-300 transition-transform duration-300 group-hover:translate-x-1 group-hover:translate-y-1 dark:bg-neutral-700 sm:block"
          />
        </>
      )
    }

    <div class="relative overflow-hidden rounded-lg bg-neutral-100 dark:bg-neutral-900">
      <Picture
        src={cover}
        alt={title}
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        formats={['webp']}
        fallbackFormat="jpeg"
        loading="lazy"
        class="aspect-[4/3] w-full object-cover transition-opacity duration-300 group-hover:opacity-90"
      />

      {
        hasMultiple && (
          <span
            class="absolute right-2 top-2 inline-flex items-center gap-1 rounded-full bg-black/65 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm"
            aria-label={`${photoCount} photos in this session`}
          >
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="3" width="14" height="14" rx="2" />
              <path d="M7 7h14v14H7z" />
            </svg>
            <span>{photoCount}</span>
          </span>
        )
      }
    </div>
  </div>

  <div class="mt-3 space-y-1">
    <h2 class="text-base font-medium">{title}</h2>
    <p class="text-xs text-neutral-600 dark:text-neutral-400">
      <time datetime={date}>{formatDate(date)}</time>
      {location && <span> · {location}</span>}
      {hasMultiple && <span class="text-neutral-500"> · {photoCount} photos</span>}
    </p>
  </div>
</a>
