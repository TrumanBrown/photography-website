---
import type { CollectionEntry } from 'astro:content';
import { hobbySlug } from '@/lib/hobbies';

interface Props {
  entry: CollectionEntry<'hobbies'>;
}

const { entry } = Astro.props;
const slug = hobbySlug(entry);
const { title, summary, emoji, accent, iconSrc, interactive } = entry.data;
const cta = interactive ? 'Play it' : 'Explore';
---

<a href={`/hobbies/${slug}`} class="group block h-full no-underline">
  <div class="flex h-full flex-col gap-4 rounded-lg border border-neutral-200 p-5 transition duration-200 hover:-translate-y-0.5 hover:border-neutral-300 hover:bg-neutral-50 hover:shadow-md dark:border-neutral-800 dark:hover:border-neutral-700 dark:hover:bg-neutral-900">
    <div
      class="flex h-14 w-14 items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800"
      style={accent ? `background-color:${accent}1a` : undefined}
      aria-hidden="true"
    >
      {
        iconSrc ? (
          <img src={iconSrc} alt="" width="40" height="40" class="h-10 w-10" />
        ) : (
          <span class="text-3xl">{emoji}</span>
        )
      }
    </div>
    <div class="space-y-1">
      <h2 class="text-base font-medium group-hover:underline">{title}</h2>
      <p class="text-sm text-neutral-600 dark:text-neutral-400">{summary}</p>
    </div>
    <div
      class="mt-auto inline-flex items-center gap-1.5 pt-1 text-sm font-semibold text-sky-600 dark:text-sky-400"
      style={accent ? `color:${accent}` : undefined}
    >
      {cta}
      <svg
        viewBox="0 0 16 16"
        width="14"
        height="14"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform duration-200 ease-out group-hover:translate-x-1"
        aria-hidden="true"
      >
        <path d="M3 8h9M9 4.5 12.5 8 9 11.5" />
      </svg>
    </div>
  </div>
</a>
