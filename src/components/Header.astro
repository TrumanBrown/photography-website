---
import { siteConfig } from '../../site.config';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  /** Active top-level section, for nav highlight + which chrome to show. */
  section?: 'photography' | 'hobbies';
}

const { section = 'photography' } = Astro.props;
const linkBase = 'no-underline hover:underline';
const activeClass = 'font-medium text-neutral-900 dark:text-neutral-100';
const idleClass = 'text-neutral-500 dark:text-neutral-400';
---

<header class="border-b border-neutral-200 dark:border-neutral-800">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-4 sm:px-6">
    <div class="flex min-w-0 items-center gap-2">
      {
        section === 'photography' && (
          <button
            id="session-nav-open"
            type="button"
            class="rounded p-1 text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-900 lg:hidden"
            aria-label="Open sessions navigation"
            aria-controls="session-nav"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 6h18M3 12h18M3 18h18" />
            </svg>
          </button>
        )
      }
      <a href="/" class="truncate text-lg font-medium tracking-tight no-underline hover:opacity-80">
        {siteConfig.siteTitle}
      </a>
    </div>
    <nav class="flex shrink-0 items-center gap-3 text-sm sm:gap-4">
      <a
        href="/"
        class:list={[linkBase, section === 'photography' ? activeClass : idleClass]}
        aria-current={section === 'photography' ? 'page' : undefined}
      >Photography</a>
      {
        siteConfig.sections.hobbies && (
          <a
            href="/hobbies"
            class:list={[linkBase, section === 'hobbies' ? activeClass : idleClass]}
            aria-current={section === 'hobbies' ? 'page' : undefined}
          >Hobbies</a>
        )
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
