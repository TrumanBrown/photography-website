---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import HobbyCard from '@/components/HobbyCard.astro';
import { sortHobbies } from '@/lib/hobbies';

const hobbies = sortHobbies(await getCollection('hobbies'));
---

<BaseLayout
  title="Hobbies"
  description="Things I do when I'm not taking photos."
  section="hobbies"
>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <header class="mb-8 space-y-2">
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Hobbies</h1>
      <p class="max-w-prose text-sm text-neutral-600 dark:text-neutral-400">
        Some stuff I do when I'm not taking photos. Each one has a little interactive piece you can play with.
      </p>
    </header>

    {
      hobbies.length === 0 ? (
        <div class="rounded-lg border border-dashed border-neutral-300 p-10 text-center text-sm text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
          Nothing here yet.
        </div>
      ) : (
        <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {hobbies.map((entry) => (
            <li>
              <HobbyCard entry={entry} />
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
