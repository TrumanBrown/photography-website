---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="That page could not be found.">
  <section class="mx-auto max-w-prose px-4 py-20 text-center sm:px-6">
    <h1 class="text-3xl font-semibold tracking-tight">404</h1>
    <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">That page doesn't exist.</p>
    <p class="mt-6">
      <a href="/" class="text-sm">← Back to sessions</a>
    </p>
  </section>
</BaseLayout>
