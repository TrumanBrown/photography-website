---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Admin" noindex>
  <section class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
    <!-- Sign-in screen (shown when not authenticated) -->
    <div id="admin-signin" class="hidden py-20 text-center">
      <h1 class="mb-3 text-2xl font-semibold tracking-tight">Session Manager</h1>
      <p class="mb-6 text-neutral-500 dark:text-neutral-400">Sign in with GitHub to manage your sessions.</p>
      <a
        href="/.auth/login/github?post_login_redirect_uri=/admin"
        class="inline-flex items-center gap-2 rounded-lg bg-neutral-900 px-6 py-3 text-sm font-medium text-white no-underline hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        Sign in with GitHub
      </a>
    </div>

    <!-- Authenticated UI -->
    <div id="admin-authed" class="hidden">
      <div class="mb-6 flex items-center justify-between">
        <h1 class="text-2xl font-semibold tracking-tight">Admin</h1>
        <div class="flex items-center gap-3 text-sm">
          <button
            id="rebuild-btn"
            type="button"
            class="rounded bg-neutral-900 px-3 py-1.5 text-white hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200"
          >Rebuild Site</button>
          <span id="admin-user" class="text-neutral-500 dark:text-neutral-400"></span>
          <a href="/.auth/logout?post_logout_redirect_uri=/admin" class="text-neutral-500 hover:text-neutral-700 dark:text-neutral-400 dark:hover:text-neutral-200">Sign out</a>
        </div>
      </div>

      <!-- Tabs -->
      <div
        class="mb-6 flex gap-1 border-b border-neutral-200 dark:border-neutral-800"
        role="tablist"
        aria-label="Admin views"
      >
        <button
          id="tab-sessions"
          type="button"
          role="tab"
          aria-selected="true"
          aria-controls="panel-sessions"
          class="border-b-2 border-neutral-900 px-4 py-2 text-sm font-medium dark:border-white"
        >Sessions</button>
        <button
          id="tab-messages"
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="panel-messages"
          tabindex="-1"
          class="border-b-2 border-transparent px-4 py-2 text-sm font-medium text-neutral-500 hover:text-neutral-700 dark:text-neutral-400 dark:hover:text-neutral-200"
        >Messages</button>
        <button
          id="tab-analytics"
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="panel-analytics"
          tabindex="-1"
          class="border-b-2 border-transparent px-4 py-2 text-sm font-medium text-neutral-500 hover:text-neutral-700 dark:text-neutral-400 dark:hover:text-neutral-200"
        >Analytics</button>
      </div>

      <!-- Sessions panel -->
      <div id="panel-sessions" role="tabpanel" aria-labelledby="tab-sessions">
        <div id="admin-loading" class="py-20 text-center text-neutral-500 dark:text-neutral-400">
          Loading sessions…
        </div>
        <div id="admin-error" class="hidden rounded-lg border border-red-300 bg-red-50 p-4 text-sm text-red-800 dark:border-red-800 dark:bg-red-950 dark:text-red-300"></div>
        <ul id="admin-list" class="hidden space-y-4"></ul>
      </div>

      <!-- Messages panel -->
      <div id="panel-messages" class="hidden" role="tabpanel" aria-labelledby="tab-messages">
        <div id="messages-loading" class="py-20 text-center text-neutral-500 dark:text-neutral-400">
          Loading messages…
        </div>
        <div id="messages-error" class="hidden rounded-lg border border-red-300 bg-red-50 p-4 text-sm text-red-800 dark:border-red-800 dark:bg-red-950 dark:text-red-300"></div>
        <ul id="messages-list" class="hidden space-y-3"></ul>
      </div>

      <!-- Analytics panel -->
      <div id="panel-analytics" class="hidden" role="tabpanel" aria-labelledby="tab-analytics">
        <div id="analytics-loading" class="py-20 text-center text-neutral-500 dark:text-neutral-400">
          Loading analytics…
        </div>
        <div id="analytics-error" class="hidden rounded-lg border border-red-300 bg-red-50 p-4 text-sm text-red-800 dark:border-red-800 dark:bg-red-950 dark:text-red-300"></div>
        <div id="analytics-content" class="hidden space-y-6">
          <div class="flex items-center justify-end">
            <label class="text-sm text-neutral-500 dark:text-neutral-400">
              Range:
              <select id="analytics-range" class="ml-2 rounded border border-neutral-300 bg-white px-2 py-1 text-sm dark:border-neutral-600 dark:bg-neutral-800">
                <option value="7">Last 7 days</option>
                <option value="30" selected>Last 30 days</option>
                <option value="90">Last 90 days</option>
              </select>
            </label>
          </div>
          <div id="analytics-cards" class="grid grid-cols-1 gap-3 sm:grid-cols-3"></div>
          <div>
            <h3 class="mb-2 text-sm font-semibold text-neutral-500 dark:text-neutral-400">Pageviews per day</h3>
            <div id="analytics-chart" class="flex h-32 items-end gap-0.5 rounded border border-neutral-200 p-2 dark:border-neutral-700"></div>
          </div>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div>
              <h3 class="mb-2 text-sm font-semibold text-neutral-500 dark:text-neutral-400">Top pages</h3>
              <ul id="analytics-pages" class="space-y-1 text-sm"></ul>
            </div>
            <div>
              <h3 class="mb-2 text-sm font-semibold text-neutral-500 dark:text-neutral-400">Top referrers</h3>
              <ul id="analytics-referrers" class="space-y-1 text-sm"></ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Edit modal -->
    <div
      id="edit-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="edit-modal-title"
      aria-hidden="true"
    >
      <div class="max-h-[calc(100vh-2rem)] w-full max-w-lg overflow-y-auto rounded-lg border border-neutral-200 bg-white p-6 shadow-xl dark:border-neutral-700 dark:bg-neutral-900">
        <h2 class="mb-4 text-lg font-semibold" id="edit-modal-title">Edit Session</h2>
        <form id="edit-form" class="space-y-4">
          <input type="hidden" id="edit-slug" />

          <div>
            <label for="edit-title" class="mb-1 block text-sm font-medium">Title</label>
            <input
              id="edit-title"
              type="text"
              maxlength="200"
              class="w-full rounded border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-neutral-500 focus:outline-none dark:border-neutral-600 dark:bg-neutral-800"
            />
          </div>

          <div>
            <label for="edit-location" class="mb-1 block text-sm font-medium">Location</label>
            <input
              id="edit-location"
              type="text"
              maxlength="200"
              class="w-full rounded border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-neutral-500 focus:outline-none dark:border-neutral-600 dark:bg-neutral-800"
            />
          </div>

          <div>
            <label for="edit-description" class="mb-1 block text-sm font-medium">Description</label>
            <textarea
              id="edit-description"
              maxlength="1000"
              rows="2"
              class="w-full rounded border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-neutral-500 focus:outline-none dark:border-neutral-600 dark:bg-neutral-800"
            ></textarea>
          </div>

          <div>
            <label class="mb-1 block text-sm font-medium">Cover / Thumbnail</label>
            <input type="hidden" id="edit-cover" />
            <div id="edit-cover-grid" class="grid max-h-64 grid-cols-4 gap-2 overflow-y-auto rounded border border-neutral-300 p-2 dark:border-neutral-600 sm:grid-cols-5"></div>
          </div>

          <details id="edit-captions" class="rounded border border-neutral-300 p-3 dark:border-neutral-600">
            <summary class="flex cursor-pointer items-center justify-between gap-3 text-sm font-medium">
              <span>Image captions</span>
              <span id="edit-caption-count" class="text-xs font-normal tabular-nums text-neutral-500 dark:text-neutral-400"></span>
            </summary>
            <div id="edit-caption-list" class="mt-3 max-h-80 space-y-3 overflow-y-auto pr-1"></div>
          </details>

          <div>
            <label for="edit-order" class="mb-1 block text-sm font-medium">Display Order</label>
            <input
              id="edit-order"
              type="number"
              step="1"
              placeholder="Auto (by date)"
              class="w-full rounded border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-neutral-500 focus:outline-none dark:border-neutral-600 dark:bg-neutral-800"
            />
            <p class="mt-1 text-xs text-neutral-500 dark:text-neutral-400">Lower numbers appear first (0 is a valid order). Leave blank to sort by date.</p>
          </div>

          <div id="edit-error" class="hidden rounded border border-red-300 bg-red-50 p-3 text-sm text-red-800 dark:border-red-800 dark:bg-red-950 dark:text-red-300"></div>

          <div class="flex items-center justify-end gap-3 pt-2">
            <button
              type="button"
              id="edit-cancel"
              class="rounded px-4 py-2 text-sm text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800"
            >Cancel</button>
            <button
              type="submit"
              id="edit-save"
              class="rounded bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200"
            >Save</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Toast -->
    <div
      id="toast"
      class="fixed bottom-6 right-6 z-50 hidden rounded-lg border border-green-300 bg-green-50 px-4 py-3 text-sm text-green-800 shadow-lg dark:border-green-800 dark:bg-green-950 dark:text-green-300"
      role="status"
      aria-live="polite"
    ></div>
  </section>

  <script src="@/lib/admin.ts"></script>
</BaseLayout>
