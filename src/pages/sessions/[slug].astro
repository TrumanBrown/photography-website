---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Lightbox from '@/components/Lightbox.astro';
import { sessionSlug, formatDate, formatExif, sortSessions } from '@/lib/sessions';
import { siteConfig } from '../../../site.config';

type SessionLink = {
  slug: string;
  title: string;
  date: string;
  location: string;
};

export async function getStaticPaths() {
  const sessions = sortSessions(await getCollection('sessions'));
  const toLink = (entry: CollectionEntry<'sessions'>): SessionLink => ({
    slug: sessionSlug(entry),
    title: entry.data.title,
    date: entry.data.date,
    location: entry.data.location,
  });
  return sessions.map((entry, index) => ({
    params: { slug: sessionSlug(entry) },
    props: {
      entry,
      previousSession: index > 0 ? toLink(sessions[index - 1]) : undefined,
      nextSession: index < sessions.length - 1 ? toLink(sessions[index + 1]) : undefined,
    },
  }));
}

interface Props {
  entry: CollectionEntry<'sessions'>;
  previousSession?: SessionLink;
  nextSession?: SessionLink;
}

const { entry, previousSession, nextSession } = Astro.props;
const slug = sessionSlug(entry);
const { title, date, location, description, images: imageList } = entry.data;

// Pull processed ImageMetadata for every image in this session.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/sessions/**/images/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true },
);

type Resolved = {
  src: ImageMetadata;
  file: string;
  caption?: string;
  exif: string;
  fullUrl: string;
};

const resolved: Resolved[] = imageList.map((img) => {
  const key = `/src/content/sessions/${slug}/images/${img.file}`;
  const mod = allImages[key];
  if (!mod) {
    throw new Error(`Image not found for session "${slug}": expected ${key}.`);
  }
  // fullUrl points at the public Blob URL when running off remote prebuild.
  // In local-only mode the prebuild leaves it empty; fall back to the local
  // file path so the lightbox still works during development.
  const fullUrl = img.fullUrl ?? mod.default.src;
  return { src: mod.default, file: img.file, caption: img.caption, exif: formatExif(img.exif), fullUrl };
});

// Social-share preview image: the session cover (or first image). Prefer the
// public Blob URL so it resolves for crawlers; fall back to the local asset.
const coverFile = entry.data.cover ?? imageList[0]?.file;
const coverResolved = resolved.find((r) => r.file === coverFile) ?? resolved[0];
const ogImage = coverResolved?.fullUrl;
const pageDescription = description || `${title}${location ? ` in ${location}` : ''}: ${imageList.length} photographs by ${siteConfig.ownerName}.`;
---

<BaseLayout
  title={title}
  description={pageDescription}
  ogImage={ogImage}
  ogImageAlt={coverResolved?.caption ?? `${title} cover photograph`}
  activeSlug={slug}
>
  <article class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <header class="mb-8 space-y-2">
      <a href="/" class="text-xs text-neutral-600 no-underline hover:underline dark:text-neutral-400">← All sessions</a>
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">{title}</h1>
      <p class="text-sm text-neutral-600 dark:text-neutral-400">
        <time datetime={date}>{formatDate(date)}</time>
        {location && <span> · {location}</span>}
      </p>
      {description && <p class="max-w-prose text-sm text-neutral-700 dark:text-neutral-300">{description}</p>}
    </header>

    <ul
      id="gallery"
      class="columns-1 gap-4 space-y-4 sm:columns-2 lg:columns-3"
    >
      {
        resolved.map((img, index) => (
          <li class="break-inside-avoid">
            <a
              href={img.fullUrl}
              data-pswp-width={img.src.width}
              data-pswp-height={img.src.height}
              data-pswp-caption={img.caption ?? ''}
              data-pswp-exif={img.exif}
              data-pswp-filename={img.file}
              class="block overflow-hidden rounded-lg bg-neutral-100 no-underline dark:bg-neutral-900"
              aria-label={img.caption ?? `${title}, photo ${index + 1} of ${resolved.length}`}
            >
              <Picture
                src={img.src}
                alt={img.caption ?? ''}
                widths={[480, 800, 1200, 1600]}
                sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                formats={['webp']}
                fallbackFormat="jpeg"
                loading={index === 0 ? 'eager' : 'lazy'}
                fetchpriority={index === 0 ? 'high' : 'auto'}
                class="h-auto w-full"
              />
            </a>
          </li>
        ))
      }
    </ul>

    <Lightbox gallerySelector="#gallery" />

    {
      (previousSession || nextSession) && (
        <nav aria-label="More photography sessions" class="mt-12 border-t border-neutral-200 pt-6 dark:border-neutral-800">
          <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Keep exploring</p>
          <div class="grid gap-4 sm:grid-cols-2">
            {previousSession && (
              <a href={`/sessions/${previousSession.slug}`} class="group no-underline">
                <span class="block text-xs text-neutral-500 dark:text-neutral-400">← Previous in archive</span>
                <span class="mt-1 block font-medium group-hover:underline">{previousSession.title}</span>
              </a>
            )}
            {nextSession && (
              <a
                href={`/sessions/${nextSession.slug}`}
                class="group no-underline sm:col-start-2 sm:text-right"
              >
                <span class="block text-xs text-neutral-500 dark:text-neutral-400">Next in archive →</span>
                <span class="mt-1 block font-medium group-hover:underline">{nextSession.title}</span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </article>
</BaseLayout>
