{
  "name": "photography-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/copy-birding-assets.mjs && astro dev",
    "build": "node scripts/copy-birding-assets.mjs && astro build",
    "copy-birding-assets": "node scripts/copy-birding-assets.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "prebuild:remote": "node scripts/prebuild.mjs",
    "prebuild:local": "node scripts/prebuild.mjs --local-only",
    "fixtures": "node scripts/generate-fixtures.mjs",
    "fixtures:many": "node scripts/generate-fixtures.mjs --many",
    "fetch:tidepool-photos": "node scripts/fetch-tidepool-photos.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js,.mjs,.ts,.astro",
    "format": "prettier --write \"**/*.{js,mjs,ts,astro,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,astro,css,json,md}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/tailwind": "^5.1.5",
    "@mediapipe/tasks-vision": "^0.10.35",
    "astro": "^5.1.0",
    "photoswipe": "^5.4.4",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/storage-blob": "^12.26.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-plugin-astro": "^1.3.1",
    "exifr": "^7.1.3",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
